{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Toggles": {
    "EnableChaos": false
  },
  "UseDatabaseCategorizer": false,
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=transactions;Username=admin;Password=admin123!"
  },
  "CategorizationRules": {
    "IsEnabled": true,
    "DefaultCategory": "Uncategorized",
    "Rules":[
    {
      "RuleName": "Groceries",
      "Category": "Groceries",
      "Priority": 1,
      "DescriptionContains": [ "supermarket", "grocery", "food", "spar", "pick n pay", "checkers", "woolworths" ]
    } ,
    {
      "RuleName": "Income",
      "Category": "Income",
      "Priority": 1,
      "DescriptionContains": [ "salary", "interest", "wage", "dividend", "bonus", "reimbursement"  ]
    },
    {
      "RuleName": "Subscriptions",
      "Category": "Subscriptions",
      "Priority": 2,
      "DescriptionContains": [ "subscription", "netflix", "spotify", "hulu", "disney+", "apple music", "stream", "membership" ]
    },
    {
      "RuleName": "OnlineShopping",
      "Category": "Online Shopping",
      "Priority": 2,
      "DescriptionContains": [ "shopping", "amazon", "ebay", "shop" , "takealot" ]
    },
    {
      "RuleName": "Utilities",
      "Category": "Utilities",
      "Priority": 5,
      "DescriptionContains": [ "electricity", "water", "gas", "utility", "municipality" ]
    },
    {
      "RuleName": "Entertainment",
      "Category": "Entertainment",
      "Priority": 2,
      "DescriptionContains": [ "movie", "concert", "entertainment" ]
    },
    {
      "RuleName": "Cellular",
      "Category": "Cellular",
      "Priority": 3,
      "DescriptionContains": [ "cellular", "mobile", "airtime","topup", "data" ]
    },
    {
      "RuleName": "Dining",
      "Category": "Dining",
      "Priority": 4,
      "DescriptionContains": [ "restaurant", "cafe", "dining", "food" ]
    },
    {
      "RuleName": "Transportation",
      "Category": "Transportation",
      "priority": 6,
      "DescriptionContains": [ "uber", "lyft", "taxi", "transportation" ]
    }, 
    {
      "RuleName": "Food",
      "Category": "Food & Drinks",
      "Priority": 4,
      "DescriptionContains": [ "takeout" , "restaurant", "cafe", "dining", "food", "uber eats", "uber-eats" ]
    }, 
    {

      "RuleName": "Health",
      "Category": "Health & Wellness",
      "Priority": 7,
      "DescriptionContains": [ "pharmacy", "health", "wellness", "gym", "fitness" ]
    }, 
    {
      "RuleName": "Education",
      "Category": "Education",
      "Priority": 8,
      "DescriptionContains": [ "education", "course", "tuition", "school", "university" ]
    },
    {
      "RuleName": "Gambling",
      "Category": "Gambling",
      "Priority": 9,
      "DescriptionContains": [ "lotto", "bet", "casino" ]
    },
        {
      "RuleName": "Finances",
      "Category": "Maintenance & Charges",
      "Priority": 1,
      "DescriptionContains": [ "repayment", "fees", "apo", "cross border" , "loan"]
    }
  ]
  }
}
