# Environment Configuration Template
# Copy this to .env and update values for your environment

# Application Environment
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# API Configuration
API_PORT=5050
API_HTTPS_PORT=5051

# Kafka Configuration
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC=transactions
KAFKA_PARTITIONS=3

# PostgreSQL Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123!
POSTGRES_DB=transactions
DATABASE_URL=postgres://admin:admin123!@postgres:5432/transactions

# Redis Configuration
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_DB=0

# Observability
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
JAEGER_SAMPLER=const
JAEGER_SAMPLER_PARAM=1

# Simulator Configuration
TRANSACTION_BATCH_SIZE=10
BATCH_INTERVAL_SECONDS=30
NUMBER_OF_SOURCES=3
LOG_LEVEL=Information

# Sync Service (Go) Configuration
SYNC_SERVICE_LOG_LEVEL=info
SYNC_SERVICE_WORKERS=4

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Timeout and Retry Policies
CONNECTION_TIMEOUT_MS=30000
REQUEST_TIMEOUT_MS=30000
RETRY_ATTEMPTS=3
CIRCUIT_BREAKER_THRESHOLD=5
