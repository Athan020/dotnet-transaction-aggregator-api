{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "TopicName": "transactions"
  },
  "OpenTelemetry": {
    "JaegerEndpoint": "http://localhost:14268/api/traces"
  },
  "SimulatorConfig": {
    "TransactionBatchSize": 10,
    "BatchIntervalSeconds": 30,
    "NumberOfSources": 3
  }
}
